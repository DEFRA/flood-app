{
  "name": "flood-app",
  "version": "8.28.0",
  "description": "Flood risk app",
  "main": "index.js",
  "repository": "github:defra/flood-app",
  "engines": {
    "node": "22.x"
  },
  "browserslist": [
    "IE 11"
  ],
  "scripts": {
    "start": "pm2 start config/pm2.json",
    "start:local": "npx nodemon --ext js,json,html,env -r dotenv/config index.js",
    "start:local:no-watch": "node -r dotenv/config index.js",
    "build:clean": "build/clean-src",
    "build:cp-assets": "build/cp-assets",
    "build:js": "build/build-js",
    "build:css": "build/build-css",
    "build": "build/build",
    "lint": "standard",
    "unit-test": "export ERRBIT_ENABLED=FALSE && export LOG_LEVEL=silent && export FLOOD_APP_LOCAL_CACHE=true && lab --verbose -c -r console -o stdout -r lcov -o coverage/lcov.info --threshold 90 --require dotenv/config",
    "unit-test:no-coverage": "export ERRBIT_ENABLED=FALSE && export LOG_LEVEL=silent && export FLOOD_APP_LOCAL_CACHE=true && lab --verbose -r console --require dotenv/config",
    "test": "npm run lint && npm run unit-test",
    "test:no-coverage": "npm run lint && npm run unit-test:no-coverage",
    "create-release-notes": "node release-docs/lib/create-release-notes.js",
    "postinstall": "npm run build",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {if (e.code !== 'MODULE_NOT_FOUND') { throw e } }\""
  },
  "author": "defra",
  "license": "ISC",
  "dependencies": {
    "@airbrake/node": "2.1.9",
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@defra/flood-webchat": "1.0.23",
    "@hapi/boom": "10.0.1",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/code": "9.0.3",
    "@hapi/h2o2": "10.0.4",
    "@hapi/hapi": "21.4.9",
    "@hapi/inert": "7.1.0",
    "@hapi/lab": "26.0.1",
    "@hapi/vision": "7.0.3",
    "@hapi/wreck": "18.1.1",
    "@hapi/yar": "11.0.3",
    "@turf/helpers": "7.3.5",
    "@turf/intersect": "7.3.5",
    "@turf/simplify": "7.3.5",
    "@turf/turf": "7.3.5",
    "babel-loader": "10.1.1",
    "body-scroll-lock": "3.1.5",
    "core-js": "3.49.0",
    "d3": "7.9.0",
    "datatables.net-buttons": "3.2.6",
    "datatables.net-buttons-dt": "3.2.6",
    "datatables.net-dt": "2.3.8",
    "elm-pep": "1.0.6",
    "geojson": "0.5.0",
    "govuk-frontend": "5.10.0",
    "hapi-pino": "13.0.0",
    "hapi-rate-limit": "8.0.0",
    "joi": "18.2.1",
    "jquery": "4.0.0",
    "lodash.isequal": "4.5.0",
    "moment-timezone": "0.6.2",
    "nunjucks": "3.2.4",
    "ol": "10.9.0",
    "pino": "10.3.1",
    "pino-abstract-transport": "3.0.0",
    "pino-pretty": "13.1.3",
    "qs": "6.15.1",
    "sass": "1.99.0",
    "standard": "17.1.2",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "yargs": "18.0.0"
  },
  "standard": {
    "ignore": [
      "server/dist",
      "service-down"
    ]
  },
  "devDependencies": {
    "dotenv": "17.4.2",
    "husky": "8.0.3",
    "jsdom": "29.1.1",
    "mockdate": "3.0.5",
    "node-html-parser": "7.1.0",
    "nodemon": "3.1.14",
    "proxyquire": "2.1.3",
    "sinon": "22.0.0"
  }
}
